# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=dbdesign
POSTGRES_PASSWORD=dbdesign_secret
POSTGRES_DB=dbdesign
# Inside Docker: host = service name "postgres"
DATABASE_URL=postgresql://dbdesign:dbdesign_secret@postgres:5432/dbdesign
# For local (non-Docker) development:
# DATABASE_URL=postgresql://dbdesign:dbdesign_secret@localhost:5432/dbdesign

# ── Redis ─────────────────────────────────────────────────────────────────────
# Inside Docker: host = service name "redis"
REDIS_URL=redis://redis:6379/0
# For local (non-Docker) development:
# REDIS_URL=redis://localhost:6379/0

# ── Gemini AI ─────────────────────────────────────────────────────────────────
# Obtain from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
# Max retries when Gemini output fails Pydantic validation (Phase 2)
GEMINI_MAX_RETRIES=2

# ── FastAPI ───────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true
# Generate a strong key for production: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_in_production
CORS_ORIGINS=http://localhost:3000

# ── Next.js (NEXT_PUBLIC_ prefix exposes these to the browser) ────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
