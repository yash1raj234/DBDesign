# ═══════════════════════════════════════════════════════════════════════════════
# DBDesign Platform — environment variables
# Copy this file to .env and fill in real values. Never commit .env.
#
# Split deployment:
#   Frontend → Vercel      (paste NEXT_PUBLIC_API_URL into Vercel dashboard)
#   Backend  → Railway / Render  (paste all other vars into Railway dashboard)
# ═══════════════════════════════════════════════════════════════════════════════

# ── Gemini AI ─────────────────────────────────────────────────────────────────
# Set on: Railway (backend service)
# Get your key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
GEMINI_MAX_RETRIES=2

# ── CORS — allowed frontend origin ────────────────────────────────────────────
# Set on: Railway (backend service)
# Set to your Vercel deployment URL once known.
# Accepts comma-separated origins:
#   CORS_ORIGINS=https://dbdesign.vercel.app,https://dbdesign-git-main-you.vercel.app
CORS_ORIGINS=http://localhost:3000

# ── Backend public URL ────────────────────────────────────────────────────────
# Set on: Vercel (frontend — Environment Variables section)
# Set to your Railway backend public URL, e.g. https://dbdesign-api.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── FastAPI ───────────────────────────────────────────────────────────────────
# Set on: Railway (backend service)
DEBUG=false
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_in_production

# ── PORT ──────────────────────────────────────────────────────────────────────
# Railway and Render inject this automatically — do NOT set it manually there.
# For local dev only:
# PORT=8000

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Set on: Railway (backend service)
# If you add Railway's Postgres plugin, DATABASE_URL is injected automatically.
POSTGRES_USER=dbdesign
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=dbdesign
DATABASE_URL=postgresql://dbdesign:change_me_strong_password@localhost:5432/dbdesign

# ── Redis ─────────────────────────────────────────────────────────────────────
# Set on: Railway (backend service)
# If you add Railway's Redis plugin, REDIS_URL is injected automatically.
REDIS_URL=redis://localhost:6379/0
